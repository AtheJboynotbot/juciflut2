rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get authenticated user's email
    function getUserEmail() {
      return request.auth.token.email;
    }
    
    // Check if the authenticated user owns this faculty document
    function isFacultyOwner(facultyData) {
      return isAuthenticated() && facultyData.email == getUserEmail();
    }
    
    // Validate faculty profile data
    function isValidFacultyData(data) {
      return data.email is string && data.email.size() > 0 &&
             // Name fields are optional but must be strings when present
             (!('first_name' in data) || data.first_name is string) &&
             (!('last_name' in data) || data.last_name is string) &&
             // Optional fields validation
             (!('department_id' in data) || data.department_id is string) &&
             (!('availability_status' in data) || data.availability_status in ['available', 'busy', 'away']) &&
             (!('profile_image_url' in data) || data.profile_image_url is string) &&
             (!('phone_number' in data) || data.phone_number is string) &&
             (!('office_location' in data) || data.office_location is string) &&
             // date_of_birth can be null, a Timestamp, or absent — never a plain string
             (!('date_of_birth' in data) || data.date_of_birth == null || data.date_of_birth is timestamp);
    }
    
    // Validate schedule data
    function isValidScheduleData(data) {
      return data.keys().hasAll(['faculty_id', 'day', 'time_start', 'time_end', 'type']) &&
             data.faculty_id is string && data.faculty_id.size() > 0 &&
             data.day is string && data.day in ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'] &&
             data.time_start is string && data.time_start.size() > 0 &&
             data.time_end is string && data.time_end.size() > 0 &&
             data.type is string && data.type in ['consultation', 'class', 'meeting', 'office_hours'] &&
             // Optional fields validation
             (!('title' in data) || data.title is string) &&
             (!('location' in data) || data.location is string) &&
             (!('isBooked' in data) || data.isBooked is bool) &&
             (!('student_email' in data) || data.student_email is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }
    
    // =========================================================================
    // FACULTY COLLECTION RULES
    // =========================================================================
    
    match /faculty/{facultyId} {
      // Any authenticated user can read faculty documents (students need this for the directory)
      allow read: if isAuthenticated();
      
      // Faculty documents are pre-created by admin only — no self-registration
      allow create: if false;
      
      // Allow update if user owns the document and email is unchanged.
      // isValidFacultyData is applied only to the fields actually being written
      // (affectedKeys) so partial updates like status toggles are not blocked
      // by unrelated fields already stored in the document.
      allow update: if isFacultyOwner(resource.data) &&
                       request.resource.data.email == resource.data.email &&
                       isValidFacultyData(request.resource.data.diff(resource.data).changedKeys().hasAny(['email','first_name','last_name','department_id','availability_status','profile_image_url','phone_number','office_location','date_of_birth'])
                         ? request.resource.data
                         : {'email': resource.data.email});
      
      // Allow delete if user owns the document
      allow delete: if isFacultyOwner(resource.data);
    }
    
    // =========================================================================
    // SCHEDULES COLLECTION RULES
    // =========================================================================
    
    match /schedules/{scheduleId} {
      // Helper to check if faculty_id belongs to authenticated user
      // Verifies that the faculty document with faculty_id has matching email
      function isFacultySchedule(facultyId) {
        return isAuthenticated() && 
               exists(/databases/$(database)/documents/faculty/$(facultyId)) &&
               get(/databases/$(database)/documents/faculty/$(facultyId)).data.email == getUserEmail();
      }
      
      // Allow read if the schedule's faculty_id belongs to authenticated user
      allow read: if isFacultySchedule(resource.data.faculty_id);
      
      // Allow create if user is creating a schedule for their own faculty profile
      allow create: if isValidScheduleData(request.resource.data) &&
                       isFacultySchedule(request.resource.data.faculty_id);
      
      // Allow update if schedule belongs to user AND validation passes
      // Cannot change faculty_id (prevent schedule hijacking)
      allow update: if isFacultySchedule(resource.data.faculty_id) &&
                       request.resource.data.faculty_id == resource.data.faculty_id &&
                       isValidScheduleData(request.resource.data);
      
      // Allow delete if schedule belongs to user
      allow delete: if isFacultySchedule(resource.data.faculty_id);
    }
    
    // =========================================================================
    // DEPARTMENTS COLLECTION RULES
    // =========================================================================
    
    match /departments/{departmentId} {
      // Anyone authenticated can read departments (reference data)
      allow read: if isAuthenticated();
      
      // Only allow writes through admin console (no client writes)
      allow write: if false;
    }
    
    // =========================================================================
    // BOOKINGS COLLECTION RULES
    // =========================================================================

    match /bookings/{bookingId} {
      // Faculty who owns this booking (faculty_id → faculty doc → email match)
      function isFacultyBooking() {
        return isAuthenticated() &&
               exists(/databases/$(database)/documents/faculty/$(resource.data.faculty_id)) &&
               get(/databases/$(database)/documents/faculty/$(resource.data.faculty_id)).data.email == getUserEmail();
      }

      // Student who owns this booking
      function isStudentBooking() {
        return isAuthenticated() && resource.data.student_email == getUserEmail();
      }

      // Faculty reads all their bookings; students read their own
      allow read: if isFacultyBooking() || isStudentBooking();

      // Students create bookings for themselves (pending only)
      allow create: if isAuthenticated() &&
                       request.resource.data.student_email == getUserEmail() &&
                       request.resource.data.status == 'pending' &&
                       request.resource.data.keys().hasAll(['schedule_id', 'faculty_id', 'student_email', 'student_name', 'status', 'reason']) &&
                       // student_id, if provided, must match the caller's Firebase Auth UID
                       (!('student_id' in request.resource.data) || request.resource.data.student_id == request.auth.uid);

      // Faculty update status (approve / reject / cancel / complete)
      // faculty_id and student_email are immutable
      allow update: if isFacultyBooking() &&
                       request.resource.data.faculty_id == resource.data.faculty_id &&
                       request.resource.data.student_email == resource.data.student_email;

      // Faculty can delete; students can delete their own bookings
      allow delete: if isFacultyBooking() || isStudentBooking();
    }

    // =========================================================================
    // NOTIFICATIONS COLLECTION RULES
    // =========================================================================

    match /notifications/{notificationId} {
      // Authenticated faculty/system can queue notification records
      allow create: if isAuthenticated();

      // Students read their own notifications — matched by email OR Firebase Auth UID
      allow read: if isAuthenticated() &&
                     (resource.data.student_email == getUserEmail() ||
                      resource.data.student_id == request.auth.uid);

      // Students can mark their own notifications as read (status update)
      allow update: if isAuthenticated() &&
                       resource.data.student_email == getUserEmail() &&
                       request.resource.data.student_email == resource.data.student_email;

      // No client-side deletes
      allow delete: if false;
    }

    // =========================================================================
    // CATCH-ALL RULE - Deny everything else
    // =========================================================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
