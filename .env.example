# JuCi Faculty Portal - Environment Configuration Template
# Copy this file to .env, .env.dev, .env.staging, or .env.prod
# and fill in your actual values

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Options: dev, staging, prod
ENVIRONMENT=dev

# =============================================================================
# FIREBASE CONFIGURATION - WEB
# =============================================================================
FIREBASE_API_KEY_WEB=your_web_api_key_here
FIREBASE_APP_ID_WEB=your_web_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_AUTH_DOMAIN=your_auth_domain_here
FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# =============================================================================
# FIREBASE CONFIGURATION - ANDROID
# =============================================================================
FIREBASE_API_KEY_ANDROID=your_android_api_key_here
FIREBASE_APP_ID_ANDROID=your_android_app_id_here

# =============================================================================
# FIREBASE CONFIGURATION - iOS
# =============================================================================
FIREBASE_API_KEY_IOS=your_ios_api_key_here
FIREBASE_APP_ID_IOS=your_ios_app_id_here
FIREBASE_ANDROID_CLIENT_ID=your_android_client_id_here
FIREBASE_IOS_CLIENT_ID=your_ios_client_id_here
FIREBASE_IOS_BUNDLE_ID=com.example.juciflut

# =============================================================================
# FIREBASE CONFIGURATION - WINDOWS
# =============================================================================
FIREBASE_API_KEY_WINDOWS=your_windows_api_key_here
FIREBASE_APP_ID_WINDOWS=your_windows_app_id_here

# =============================================================================
# FIRESTORE DATABASE
# =============================================================================
# Database ID for Firestore (leave empty for default database)
FIREBASE_DATABASE_ID=facconsult-firebase

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
# API URLs (if you have backend services)
# API_BASE_URL=https://api.yourapp.com
# API_TIMEOUT=30000

# Feature Flags
# ENABLE_ANALYTICS=true
# ENABLE_CRASHLYTICS=true
# ENABLE_DEBUG_LOGGING=true

# App Configuration
# APP_NAME=JuCi Faculty Portal
# APP_VERSION=1.0.0
